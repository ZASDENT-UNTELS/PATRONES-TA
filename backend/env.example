# ============================================================
# .env.example — Plantilla de variables de entorno
# ============================================================
# Copia este archivo como ".env" y rellena los valores reales.
# Este archivo SÍ se sube a Git (no tiene credenciales reales).
#
#   cp .env.example .env
# ============================================================

# ── Base de datos ────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=nombre_de_tu_bd
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ── Aplicación ───────────────────────────────────────────────
APP_NAME="ZAZDENT"
APP_ENV=local
APP_DEBUG=true

# ── Correo (PHPMailer) ───────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME="ZAZDENT Clínica"
